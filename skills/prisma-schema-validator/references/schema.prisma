  @@unique([messageId, userId, deviceId])
  @@index([messageId, userId, readAt])
  @@index([userId, deviceId, readAt])
  @@index([userId, readAt])
  @@map("chat_read_receipts")
}

model ChatPushNotification {
  id               String   @id @default(uuid())
  recipientUserIds String[]
  notificationType String
  title            String
  body             String
  data             Json     @default("{}")
  platformResults  Json     @default("{}")
  totalSent        Int      @default(0)
  totalDelivered   Int      @default(0)
  totalFailed      Int      @default(0)
  sentAt           DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([recipientUserIds])
  @@index([notificationType, sentAt])
  @@map("chat_push_notifications")
}

model ChatDeviceSyncEvent {
  id               String        @id @default(uuid())
  userId           String
  sourceDeviceId   String
  targetDeviceIds  String[]      @default([])
  eventType        String
  messageId        String?
  syncData         Json          @default("{}")
  success          Boolean       @default(true)
  errorMessage     String?
  processingTimeMs Int?
  createdAt        DateTime      @default(now())
  message          GroupMessage? @relation("MessageSyncEvents", fields: [messageId], references: [id])
  user             User          @relation("UserSyncEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sourceDeviceId, eventType, createdAt])
  @@index([eventType, success, processingTimeMs, createdAt])
  @@map("chat_device_sync_events")
}

model ChatUserKey {
  id              String                   @id @default(uuid())
  userId          String
  deviceId        String
  keyId           String                   @unique
  publicKey       String
  privateKeyHash  String
  keyStatus       String                   @default("active")
  expiresAt       DateTime
  lastUsedAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  auditEvents     ChatKeyAuditEvent[]      @relation("KeyAuditEvents")
  keyExchangeFrom ChatKeyExchangeRequest[] @relation("KeyExchangeFromUser")
  keyExchangeTo   ChatKeyExchangeRequest[] @relation("KeyExchangeToUser")
  device          ChatDeviceSession        @relation("DeviceEncryptionKeys", fields: [userId, deviceId], references: [userId, deviceId], onDelete: Cascade)
  user            User                     @relation("UserEncryptionKeys", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId, keyStatus, expiresAt])
  @@index([deviceId, keyStatus])
  @@index([expiresAt])
  @@map("chat_user_keys")
}

model ChatGroupKey {
  id              String              @id @default(uuid())
  groupId         String
  keyId           String              @unique
  encryptedKey    String
  keyVersion      Int                 @default(1)
  createdBy       String
  isActive        Boolean             @default(true)
  authorizedUsers Json                @default("[]")
  createdAt       DateTime            @default(now())
  creator         User                @relation("CreatedGroupKeys", fields: [createdBy], references: [id], onDelete: Cascade)
  group           Group               @relation("GroupEncryptionKeys", fields: [groupId], references: [id], onDelete: Cascade)
  auditEvents     ChatKeyAuditEvent[] @relation("GroupKeyAuditEvents")

  @@unique([groupId, keyVersion])
  @@index([groupId, isActive])
  @@index([createdBy, createdAt])
  @@map("chat_group_keys")
}

model ChatKeyExchangeRequest {
  id           String      @id @default(uuid())
  requestId    String      @unique
  fromUserId   String
  toUserId     String
  fromDeviceId String
  toDeviceId   String
  publicKey    String
  status       String      @default("pending")
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  fromUser     User        @relation("SentKeyExchangeRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  fromKey      ChatUserKey @relation("KeyExchangeFromUser", fields: [fromUserId, fromDeviceId], references: [userId, deviceId], onDelete: Cascade)
  toUser       User        @relation("ReceivedKeyExchangeRequests", fields: [toUserId], references: [id], onDelete: Cascade)
  toKey        ChatUserKey @relation("KeyExchangeToUser", fields: [toUserId, toDeviceId], references: [userId, deviceId], onDelete: Cascade)

  @@index([toUserId, status, expiresAt])
  @@index([fromUserId, createdAt])
  @@index([expiresAt])
  @@map("chat_key_exchange_requests")
}

model ChatKeyAuditEvent {
  id         String        @id @default(uuid())
  eventId    String        @unique
  eventType  String
  keyType    String
  userId     String
  deviceId   String?
  userKeyId  String?
  groupKeyId String?
  groupId    String?
  metadata   Json          @default("{}")
  timestamp  DateTime      @default(now())
  ipAddress  String?
  userAgent  String?
  group      Group?        @relation("GroupKeyAuditEvents", fields: [groupId], references: [id])
  groupKey   ChatGroupKey? @relation("GroupKeyAuditEvents", fields: [groupKeyId], references: [keyId], onDelete: Cascade)
  user       User          @relation("UserKeyAuditEvents", fields: [userId], references: [id], onDelete: Cascade)
  userKey    ChatUserKey?  @relation("KeyAuditEvents", fields: [userKeyId], references: [keyId], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([eventType, timestamp])
  @@index([userKeyId, timestamp])
  @@index([groupKeyId, timestamp])
  @@index([keyType, timestamp])
  @@map("chat_key_audit_events")
}

model ChatSecurityEvent {
  id        String             @id @default(uuid())
  eventType String
  userId    String?
  sessionId String?
  ipAddress String?
  userAgent String?
  timestamp DateTime           @default(now())
  metadata  Json               @default("{}")
  riskScore Decimal            @default(0.0)
  blocked   Boolean            @default(false)
  device    ChatDeviceSession? @relation("DeviceSecurityEvents", fields: [sessionId], references: [socketId])
  user      User?              @relation("UserSecurityEvents", fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([eventType, timestamp])
  @@index([ipAddress, timestamp])
  @@index([riskScore, timestamp])
  @@map("chat_security_events")
}

model ChatDeviceFingerprint {
  id             String            @id @default(uuid())
  deviceId       String            @unique
  userId         String
  fingerprint    String
  userAgent      String?
  acceptLanguage String?
  acceptEncoding String?
  riskScore      Decimal           @default(0.0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  device         ChatDeviceSession @relation("DeviceFingerprint", fields: [deviceId], references: [deviceId], onDelete: Cascade)
  user           User              @relation("UserDeviceFingerprints", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([riskScore, updatedAt])
  @@map("chat_device_fingerprints")
}

model ChatRateLimitEntry {
  id             String    @id @default(uuid())
  identifier     String    @unique
  windowStart    DateTime
  requestCount   Int       @default(0)
  violations     Int       @default(0)
  blockedUntil   DateTime?
  firstViolation DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([identifier, windowStart])
  @@index([blockedUntil])
  @@index([violations, updatedAt])
  @@map("chat_rate_limit_entries")
}

model ChatContentFilterViolation {
  id               String   @id @default(uuid())
  userId           String
  contentHash      String
  violationType    String
  filterName       String
  severity         String
  actionTaken      String
  originalContent  String?
  sanitizedContent String?
  threatTypes      String[] @default([])
  confidenceScore  Decimal?
  createdAt        DateTime @default(now())
  user             User     @relation("UserContentViolations", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([violationType, severity, createdAt])
  @@index([contentHash])
  @@map("chat_content_filter_violations")
}

model ChatBlockedIdentifier {
  id             String    @id @default(uuid())
  identifier     String    @unique
  blockedBy      String    @default("system")
  reason         String?
  blockedAt      DateTime  @default(now())
  expiresAt      DateTime?
  isPermanent    Boolean   @default(false)
  violationCount Int       @default(1)
  lastViolation  DateTime  @default(now())

  @@index([expiresAt])
  @@index([isPermanent, blockedAt])
  @@map("chat_blocked_identifiers")
}

model FinancialAuditEntry {
  id                String       @id @default(uuid())
  userId            String
  walletId          String?
  transactionId     String?
  operationType     String
  operationSubtype  String?
  amount            String?
  currency          String?
  balanceBefore     String?
  balanceAfter      String?
  description       String
  metadata          Json?
  complianceFlags   String[]
  riskScore         Int?
  deviceFingerprint String?
  ipAddress         String?
  userAgent         String?
  correlationId     String
  parentAuditId     String?
  timestamp         DateTime     @default(now())
  checksum          String?
  transaction       Transaction? @relation(fields: [transactionId], references: [id])
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet            Wallet?      @relation(fields: [walletId], references: [id])

  @@index([userId, timestamp])
  @@index([walletId, timestamp])
  @@index([transactionId, timestamp])
  @@index([operationType, timestamp])
  @@index([correlationId])
  @@index([timestamp])
  @@index([riskScore])
  @@index([complianceFlags])
  @@map("financial_audit_entries")
}

model BlockchainTransaction {
  id                  String                   @id @default(uuid())
  network             BlockchainNetwork
  blockchainTxId      String                   @unique
  blockHeight         Int?
  confirmations       Int                      @default(0)
  isFullyConfirmed    Boolean                  @default(false)
  rawTransactionHex   String?
  transactionSize     Int?
  virtualSize         Int?
  inputs              Json                     @default("[]")
  outputs             Json                     @default("[]")
  signatures          Json                     @default("[]")
  witnessData         Json?
  networkResponse     Json?
  broadcastStatus     String?
  broadcastError      String?
  networkFee          Decimal
  feeRate             Decimal?
  broadcastAt         DateTime?
  confirmedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  gojiTransactions Transaction[]            @relation("BlockchainToGojiTransactions")
  confirmationHistory BlockchainConfirmation[]

  @@index([blockchainTxId])
  @@index([network, blockHeight])
  @@index([isFullyConfirmed, confirmations])
  @@map("blockchain_transactions")
}

model Otp {
  id            String         @id @default(uuid())
  userId        String? // Optional - for logged-in users
  email         String? // Either email or phoneNumber must be provided
  phoneNumber   String?
  otp           String // The actual OTP code
  type          OtpTypeEnum // EMAIL or PHONE
  purpose       OtpPurposeEnum // REGISTRATION, LOGIN, EMAIL_VERIFICATION, PHONE_VERIFICATION, PASSWORD_RESET, 2FA
  attempts      Int            @default(0) // Number of verification attempts
  maxAttempts   Int            @default(3) // Maximum allowed attempts
  isVerified    Boolean        @default(false)
  isInvalidated Boolean        @default(false) // True when a new OTP is requested
  expiresAt     DateTime // OTP expiration timestamp
  verifiedAt    DateTime? // When the OTP was successfully verified
  invalidatedAt DateTime? // When the OTP was invalidated
  ipAddress     String? // IP address of the request
  userAgent     String? // User agent string
  metadata      Json? // Additional metadata
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Optional relation to User
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for performance
  @@index([userId])
  @@index([email])
  @@index([phoneNumber])
  @@index([type, purpose])
  @@index([expiresAt])
  @@index([isInvalidated, isVerified])
  @@map("otps")
}

model OtpAutoRegeneration {
  id          String   @id @default(uuid())
  otpId       String // Original expired OTP ID
  userId      String? // Optional - may be null for pre-registration
  email       String?
  phoneNumber String?
  ipAddress   String?
  userAgent   String?
  reason      String   @default("expired_submission") // Reason for auto-regeneration
  createdAt   DateTime @default(now())

  // Indexes for rate limiting queries
  @@index([email, createdAt])
  @@index([phoneNumber, createdAt])
  @@index([userId, createdAt])
  @@map("otp_auto_regenerations")
}

model SentEmail {
  id           String   @id @default(uuid())
  toEmail      String // Recipient email address
  subject      String // Email subject line
  template     String // Template identifier (email-otp, password-reset, etc.)
  templateData Json // Template data (otp, expirationMinutes, etc.)
  status       String // sent, failed
  provider     String // mock, resend, sendgrid
  messageId    String? // External provider message ID (for tracking)
  error        String? // Error message if failed
  createdAt    DateTime @default(now())
  expiresAt    DateTime? // When the email should expire (for mock provider cleanup)

  // Indexes for querying
  @@index([toEmail])
  @@index([provider])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("sent_emails")
}

model BlockchainConfirmation {
  id                      String                @id @default(uuid())
  blockchainTransactionId String
  confirmationCount       Int
  blockHeight             Int?
  blockHash               String?
  detectedBy              String                @default("system")
  detectionMethod         String?
  detectedAt              DateTime              @default(now())
  blockchainTransaction   BlockchainTransaction @relation(fields: [blockchainTransactionId], references: [id], onDelete: Cascade)

  @@index([blockchainTransactionId, confirmationCount])
  @@index([blockHeight])
  @@map("blockchain_confirmations")
}

