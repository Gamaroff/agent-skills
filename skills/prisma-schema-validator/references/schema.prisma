generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                       @id @default(uuid())
  email                       String                       @unique
  handle                      String?                      @unique
  firstName                   String?
  lastName                    String?
  displayName                 String?
  bio                         String?
  status                      String?
  dateOfBirth                 DateTime?
  profileImageUrl             String?
  country                     String?
  region                      String?
  timezone                    String?
  passwordHash                String?
  authMethod                  AuthMethodEnum               @default(PASSWORD)
  isEmailVerified             Boolean                      @default(false)
  isPhoneVerified             Boolean                      @default(false)
  phoneNumber                 String?                      @unique
  lastLoginAt                 DateTime?
  twoFactorEnabled            Boolean                      @default(false)
  twoFactorSecret             String?
  biometricEnabled            Boolean                      @default(false)
  faceIdEnabled               Boolean                      @default(false)
  fingerprintEnabled          Boolean                      @default(false)
  securityQuestions           Json?
  socialProviderId            String?
  socialProvider              String?
  socialProviderEmail         String?
  socialAccessToken           String?
  socialRefreshToken          String?
  socialTokenExpiresAt        DateTime?
  socialProfileData           Json?
  socialVerifiedEmail         Boolean                      @default(false)
  socialAccountCreatedAt      DateTime?
  kycTier                     KycTierEnum                  @default(TIER_0)
  kycStatus                   KycStatusEnum                @default(PENDING)
  kycDocumentStatus           Json?
  creditScore                 Decimal?
  riskScore                   Decimal?
  amlFlags                    String[]                     @default([])
  sanctionsScreened           Boolean                      @default(false)
  profileVisibility           ProfileVisibilityEnum        @default(PUBLIC)
  onlineStatus                UserStatusEnum               @default(OFFLINE)
  lastSeenAt                  DateTime?
  allowContactRequests        Boolean                      @default(true)
  chatPreferences             Json?
  language                    String                       @default("en")
  currency                    String                       @default("USD")
  theme                       String                       @default("light")
  dataConsentVersion          String?
  gdprConsent                 Boolean                      @default(false)
  accountStatus               AccountStatusEnum            @default(ACTIVE)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  alertAuditLogs              AlertAuditLog[]
  contentViolations           ChatContentFilterViolation[] @relation("UserContentViolations")
  deviceFingerprints          ChatDeviceFingerprint[]      @relation("UserDeviceFingerprints")
  deviceSessions              ChatDeviceSession[]          @relation("UserDeviceSessions")
  syncEvents                  ChatDeviceSyncEvent[]        @relation("UserSyncEvents")
  createdGroupKeys            ChatGroupKey[]               @relation("CreatedGroupKeys")
  keyAuditEvents              ChatKeyAuditEvent[]          @relation("UserKeyAuditEvents")
  sentKeyExchangeRequests     ChatKeyExchangeRequest[]     @relation("SentKeyExchangeRequests")
  receivedKeyExchangeRequests ChatKeyExchangeRequest[]     @relation("ReceivedKeyExchangeRequests")
  offlineMessages             ChatOfflineMessage[]         @relation("UserOfflineMessages")
  readReceipts                ChatReadReceipt[]            @relation("UserReadReceipts")
  securityEvents              ChatSecurityEvent[]          @relation("UserSecurityEvents")
  encryptionKeys              ChatUserKey[]                @relation("UserEncryptionKeys")
  contacts                    Contact[]
  ownedExternalContacts       ExternalContact[]            @relation("OwnedExternalContacts")
  financialAuditEntries       FinancialAuditEntry[]
  groupMemberships            GroupMember[]
  identityDocuments           IdentityDocument[]
  kycVerification             KycVerification?
  notificationPreferences     NotificationPreference[]
  notifications               Notification[]
  receivedRequests            PaymentRequest[]             @relation("RequestToUser")
  sentRequests                PaymentRequest[]             @relation("RequestFromUser")
  productReviews              ProductReview[]
  productShares               ProductShare[]
  rewards                     Reward[]
  shoppingPurchases           ShoppingPurchase[]
  shoppingRecommendations     ShoppingRecommendation[]
  shoppingProfile             ShoppingUserProfile?
  socialAccounts              SocialAccount[]
  receivedTransactions        Transaction[]                @relation("TransactionToUser")
  transactions                Transaction[]                @relation("UserTransactions")
  contactOf                   UserContact[]                @relation("ContactOf")
  ownedContacts               UserContact[]                @relation("OwnedContacts")
  suspensions                 UserSuspension[]
  wallets                     Wallet[]
  usedAddresses               UsedAddress[]
  otps                        Otp[]                        @relation()

  @@map("users")
}

model SocialAccount {
  id               String    @id @default(uuid())
  userId           String
  provider         String
  providerId       String
  providerEmail    String?
  accessToken      String?
  refreshToken     String?
  tokenExpiresAt   DateTime?
  scope            String?
  profileData      Json?
  emailVerified    Boolean   @default(false)
  phoneVerified    Boolean   @default(false)
  profileImageUrl  String?
  accountCreatedAt DateTime?
  lastSyncAt       DateTime?
  isActive         Boolean   @default(true)
  linkedAt         DateTime  @default(now())
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@index([userId, isActive])
  @@index([provider, providerId])
  @@map("social_accounts")
}

model Wallet {
  id                    String                @id @default(uuid())
  userId                String
  type                  String
  changePublicKey       String
  receivePublicKey      String
  address               String?
  balance               Decimal               @default(0)
  status                String?               @default("ACTIVE")
  lastSyncAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  financialAuditEntries FinancialAuditEntry[]
  shoppingPurchases     ShoppingPurchase[]
  transactions          Transaction[]
  usedAddresses         UsedAddress[]
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("wallets")
}

model UsedAddress {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  walletId      String       @map("wallet_id")
  protocolId    String       @map("protocol_id") @db.VarChar(100)
  keyId         String       @map("key_id") @db.VarChar(500)
  counterparty  String       @db.VarChar(100)
  address       String       @db.VarChar(100)
  publicKey     String       @map("public_key") @db.Text
  currency      String       @db.VarChar(10)
  context       String       @db.VarChar(50)
  contextId     String?      @map("context_id") @db.VarChar(500)
  isUsed        Boolean      @default(false) @map("is_used")
  usedAt        DateTime?    @map("used_at")
  transactionId String?      @map("transaction_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet        Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@unique([walletId, keyId], name: "unique_wallet_keyid")
  @@index([userId, walletId], name: "idx_user_wallet")
  @@index([keyId], name: "idx_key_id")
  @@index([address], name: "idx_address")
  @@index([currency, context, contextId], name: "idx_context")
  @@map("used_addresses")
}

model Transaction {
  id                      String                 @id @default(uuid())
  userId                  String
  walletId                String?
  type                    TransactionTypeEnum
  status                  TransactionStatusEnum  @default(PENDING)
  amount                  Decimal
  fee                     Decimal                @default(0)
  currency                String
  toUserId                String?
  chatId                  String?
  description             String?
  memo                    String?
  blockchainTransactionId String?
  blockchainOutputIndex   Int?
  deletedAt               DateTime?
  deletedBy               String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  financialAuditEntries   FinancialAuditEntry[]
  blockchainData          BlockchainTransaction? @relation("BlockchainToGojiTransactions", fields: [blockchainTransactionId], references: [id])
  toUser                  User?                  @relation("TransactionToUser", fields: [toUserId], references: [id])
  user                    User                   @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)
  wallet                  Wallet?                @relation(fields: [walletId], references: [id])
  chat                    Group?                 @relation(fields: [chatId], references: [id])
  paymentRequest          PaymentRequest?        @relation("TransactionPaymentRequest")
  paymentMessage          GroupMessage?
  usedAddresses           UsedAddress[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([toUserId, createdAt(sort: Desc)])
  @@index([blockchainTransactionId])
  @@index([blockchainTransactionId, blockchainOutputIndex])
  @@index([chatId, deletedAt])
  @@index([chatId, createdAt(sort: Desc)])
  @@index([deletedAt, status])
  @@map("transactions")
}

model Contact {
  id                 String        @id @default(uuid())
  userId             String
  name               String
  type               String
  paymentDetails     Json
  avatarUrl          String?
  isFavorite         Boolean       @default(false)
  trustLevel         String        @default("new")
  lastInteractionAt  DateTime?
  interactionCount   Int           @default(0)
  totalPaymentVolume Decimal       @default(0)
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupMemberships   GroupMember[]

  @@unique([userId, type, paymentDetails])
  @@index([userId, type])
  @@index([userId, isFavorite])
  @@map("contacts")
}

model UserContact {
  id                 String          @id @default(uuid())
  ownerId            String
  contactUserId      String
  nickname           String?
  notes              String?
  isFavorite         Boolean         @default(false)
  trustLevel         String          @default("new")
  status             String          @default("ACTIVE")
  lastInteractionAt  DateTime?
  interactionCount   Int             @default(0)
  totalPaymentVolume Decimal         @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  paymentMethods     PaymentMethod[]
  contactUser        User            @relation("ContactOf", fields: [contactUserId], references: [id], onDelete: Cascade)
  owner              User            @relation("OwnedContacts", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contactUserId])
  @@index([ownerId, status])
  @@index([ownerId, isFavorite])
  @@index([contactUserId])
  @@map("user_contacts")
}

model ExternalContact {
  id                 String          @id @default(uuid())
  ownerId            String
  name               String
  type               String
  country            String?
  isFavorite         Boolean         @default(false)
  trustLevel         String          @default("new")
  isActive           Boolean         @default(true)
  lastInteractionAt  DateTime?
  interactionCount   Int             @default(0)
  totalPaymentVolume Decimal         @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  owner              User            @relation("OwnedExternalContacts", fields: [ownerId], references: [id], onDelete: Cascade)
  paymentMethods     PaymentMethod[]

  @@index([ownerId, type])
  @@index([ownerId, isFavorite])
  @@map("external_contacts")
}

model PaymentMethod {
  id                String           @id @default(uuid())
  userContactId     String?
  externalContactId String?
  type              String
  label             String
  paymentDetails    Json
  isDefault         Boolean          @default(false)
  isVerified        Boolean          @default(false)
  verifiedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  externalContact   ExternalContact? @relation(fields: [externalContactId], references: [id], onDelete: Cascade)
  userContact       UserContact?     @relation(fields: [userContactId], references: [id], onDelete: Cascade)

  @@index([userContactId, isDefault])
  @@index([externalContactId, isDefault])
  @@index([type])
  @@map("payment_methods")
}

model Group {
  id                  String              @id @default(uuid())
  name                String
  description         String?
  avatarUrl           String?
  type                String
  joinMode            String              @default("invite_only")
  capabilities        String[]            @default([])
  savingsEnabled      Boolean             @default(false)
  savingsGoal         Decimal?
  savingsDeadline     DateTime?
  savingsRules        Json?
  bettingEnabled      Boolean             @default(false)
  bettingRules        Json?
  bettingDeadline     DateTime?
  monetizationEnabled Boolean             @default(false)
  defaultContentPrice Decimal?
  monetizationRules   Json?
  pokerEnabled        Boolean             @default(false)
  pokerConfig         Json?
  pokerDeadline       DateTime?
  isReadOnly          Boolean             @default(false)
  autoArchiveAfter    Int?
  memberLimit         Int                 @default(1000)
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  lastActivityAt      DateTime            @default(now())
  visibility          GroupVisibility     @default(PRIVATE)
  bettingPools        BettingPool[]
  encryptionKeys      ChatGroupKey[]      @relation("GroupEncryptionKeys")
  keyAuditEvents      ChatKeyAuditEvent[] @relation("GroupKeyAuditEvents")
  members             GroupMember[]
  messages            GroupMessage[]
  ProductShare        ProductShare[]
  transactions        Transaction[]

  @@index([type, visibility])
  @@index([capabilities])
  @@index([lastActivityAt])
  @@index([deletedAt, lastActivityAt])
  @@map("groups")
}

model GroupMember {
  id                  String         @id @default(uuid())
  groupId             String
  userId              String?
  contactId           String?
  role                String
  permissions         String[]       @default(["chat"])
  status              String         @default("active")
  joinedAt            DateTime       @default(now())
  lastReadAt          DateTime?
  lastActiveAt        DateTime       @default(now())
  invitedBy           String?
  approvedAt          DateTime?
  approvedBy          String?
  savingsContribution Decimal        @default(0)
  bettingBalance      Decimal        @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  contact             Contact?       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group               Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user                User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  GroupMessage        GroupMessage[]

  @@unique([groupId, userId])
  @@unique([groupId, contactId])
  @@index([userId, status])
  @@index([groupId, role])
  @@index([status, lastActiveAt])
  @@map("group_members")
}

model GroupMessage {
  id                  String                @id @default(uuid())
  groupId             String
  senderId            String
  senderMemberId      String
  content             String
  text                String?
  contentType         String                @default("text")
  mediaDuration       Int?
  mediaSize           BigInt?
  thumbnailUrl        String?
  isPayment           Boolean               @default(false)
  paymentAmount       Decimal?
  paymentCurrency     String?
  paymentRecipients   String[]              @default([])
  paymentStatus       String?
  transactionId       String?               @unique
  isMonetized         Boolean               @default(false)
  accessPrice         Decimal?
  accessCurrency      String?
  accessCount         Int                   @default(0)
  monetizationGoal    Json?
  unlockDeadline      DateTime?
  savingsData         Json?
  bettingPoolId       String?
  billSplitData       Json?
  productShareData    Json?
  giftCodeData        Json?
  reactions           Json?
  mentions            String[]              @default([])
  linkPreviews        Json?
  replyToMessageId    String?
  threadMessageIds    String[]              @default([])
  editedAt            DateTime?
  deletedAt           DateTime?
  pinnedAt            DateTime?
  pinnedBy            String?
  isEdited            Boolean               @default(false)
  isDeleted           Boolean               @default(false)
  deliveredTo         String[]              @default([])
  readBy              String[]              @default([])
  status              MessageStatusEnum     @default(MESSAGE_SENT)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  syncEvents          ChatDeviceSyncEvent[] @relation("MessageSyncEvents")
  offlineMessageQueue ChatOfflineMessage[]  @relation("MessageOfflineQueue")
  readReceipts        ChatReadReceipt[]     @relation("MessageReadReceipts")
  contentAccess       ContentAccess[]
  ContentGoal         ContentGoal?
  bettingPool         BettingPool?          @relation(fields: [bettingPoolId], references: [id])
  group               Group                 @relation(fields: [groupId], references: [id], onDelete: Cascade)
  replyTo             GroupMessage?         @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies             GroupMessage[]        @relation("MessageReplies")
  member              GroupMember           @relation(fields: [senderMemberId], references: [id], onDelete: Cascade)
  transaction         Transaction?          @relation(fields: [transactionId], references: [id])
  mediaAttachments    MediaAttachment[]

  @@index([groupId, createdAt])
  @@index([senderId, createdAt])
  @@index([contentType, createdAt])
  @@index([isMonetized, accessPrice])
  @@index([bettingPoolId])
  @@index([replyToMessageId])
  @@index([status, createdAt])
  @@map("group_messages")
}

model MediaAttachment {
  id               String       @id @default(uuid())
  messageId        String
  fileName         String
  originalFileName String
  fileSize         BigInt
  mimeType         String
  mediaType        String
  url              String
  thumbnailUrl     String?
  previewUrl       String?
  dimensions       Json?
  duration         Int?
  bitrate          Int?
  resolution       String?
  processingStatus String       @default("pending")
  processedAt      DateTime?
  isEncrypted      Boolean      @default(false)
  encryptionKey    String?
  accessLevel      String       @default("group")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  message          GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([mediaType, processingStatus])
  @@index([createdAt])
  @@map("media_attachments")
}

model BettingPool {
  id                 String           @id @default(uuid())
  groupId            String
  creatorId          String
  title              String
  description        String
  category           String
  minBet             Decimal
  maxBet             Decimal
  maxPoolSize        Int?
  currency           String
  entryDeadline      DateTime
  resultDeadline     DateTime
  status             String           @default("open")
  totalPool          Decimal          @default(0)
  participantCount   Int              @default(0)
  winningOutcome     String?
  evidenceLinks      String[]         @default([])
  moderatorId        String?
  resolvedAt         DateTime?
  payoutCompleted    Boolean          @default(false)
  requiresModeration Boolean          @default(true)
  ageRestricted      Boolean          @default(false)
  regionRestricted   String[]         @default([])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  outcomes           BettingOutcome[]
  bets               BettingPoolBet[]
  group              Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  messages           GroupMessage[]

  @@index([groupId, status])
  @@index([status, entryDeadline])
  @@index([category, status])
  @@map("betting_pools")
}

model BettingOutcome {
  id          String           @id @default(uuid())
  poolId      String
  label       String
  description String?
  odds        Decimal?
  isWinner    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  pool        BettingPool      @relation(fields: [poolId], references: [id], onDelete: Cascade)
  bets        BettingPoolBet[]

  @@index([poolId])
  @@map("betting_outcomes")
}

model BettingPoolBet {
  id                  String         @id @default(uuid())
  poolId              String
  outcomeId           String
  userId              String
  amount              Decimal
  currency            String
  transactionId       String?
  status              String         @default("placed")
  payout              Decimal?
  payoutTransactionId String?
  createdAt           DateTime       @default(now())
  outcome             BettingOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  pool                BettingPool    @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([poolId, outcomeId, userId])
  @@index([userId, status])
  @@index([poolId, status])
  @@map("betting_pool_bets")
}

model ContentAccess {
  id               String          @id @default(uuid())
  messageId        String
  userId           String
  accessType       String
  paymentAmount    Decimal?
  paymentCurrency  String?
  transactionId    String?
  goalContribution Boolean         @default(false)
  goalId           String?
  accessGrantedAt  DateTime        @default(now())
  accessExpiresAt  DateTime?
  createdAt        DateTime        @default(now())
  goal             ContentGoal?    @relation(fields: [goalId], references: [id])
  message          GroupMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  refunds          ContentRefund[]

  @@unique([messageId, userId, accessType])
  @@index([userId, accessGrantedAt])
  @@index([messageId, accessType])
  @@map("content_access")
}

model ContentGoal {
  id                 String          @id @default(uuid())
  messageId          String          @unique
  targetAmount       Decimal?
  targetBackers      Int?
  deadline           DateTime
  description        String?
  totalRaised        Decimal         @default(0)
  backersCount       Int             @default(0)
  status             String          @default("active")
  fallbackPolicy     String          @default("refund_all")
  gracePeriodHours   Int             @default(72)
  minRevealThreshold Decimal?
  goalReachedAt      DateTime?
  goalExpiredAt      DateTime?
  refundsProcessed   Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  contributions      ContentAccess[]
  message            GroupMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  refunds            ContentRefund[]

  @@index([status, deadline])
  @@index([messageId])
  @@map("content_goals")
}

model ContentRefund {
  id              String        @id @default(uuid())
  contentAccessId String
  goalId          String?
  userId          String
  refundAmount    Decimal
  refundCurrency  String
  refundReason    String
  processed       Boolean       @default(false)
  processedAt     DateTime?
  transactionId   String?
  createdAt       DateTime      @default(now())
  contentAccess   ContentAccess @relation(fields: [contentAccessId], references: [id], onDelete: Cascade)
  goal            ContentGoal?  @relation(fields: [goalId], references: [id])

  @@index([processed, createdAt])
  @@index([userId, processed])
  @@map("content_refunds")
}

model Reward {
  id        String   @id @default(uuid())
  userId    String
  points    Int      @default(0)
  tier      String   @default("BRONZE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rewards")
}

model KycVerification {
  id                 String            @id @default(uuid())
  userId             String            @unique
  status             String
  level              String
  documentType       String?
  documentNumber     String?
  expiryDate         DateTime?
  documentFrontImage String?
  documentBackImage  String?
  selfieImage        String?
  addressProofImage  String?
  documentExpiry     DateTime?
  documentCountry    String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  postalCode         String?
  country            String?
  rejectionReason    String?
  verifiedAt         DateTime?
  reviewedBy         String?
  reviewNotes        String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  documentLinks      KycDocumentLink[]
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_verifications")
}

model Notification {
  id          String                    @id @default(uuid())
  userId      String
  title       String
  message     String
  type        NotificationTypeEnum
  priority    NotificationPriorityEnum  @default(MEDIUM)
  channels    NotificationChannelEnum[]
  status      NotificationStatusEnum    @default(pending)
  metadata    Json?
  templateId  String?
  scheduledAt DateTime?
  expiresAt   DateTime?
  readAt      DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  deliveries  NotificationDelivery[]
  template    NotificationTemplate?     @relation(fields: [templateId], references: [id])
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([type, priority])
  @@index([status, scheduledAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String                  @id @default(uuid())
  notificationId String
  channel        NotificationChannelEnum
  provider       String?
  externalId     String?
  status         DeliveryStatusEnum      @default(pending)
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  failedAt       DateTime?
  failureReason  String?
  metadata       Json?
  createdAt      DateTime                @default(now())
  notification   Notification            @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, channel])
  @@index([status, createdAt])
  @@index([channel, status])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id             String                    @id @default(uuid())
  userId         String
  type           NotificationTypeEnum
  channels       NotificationChannelEnum[]
  enabled        Boolean                   @default(true)
  quietHours     Json?
  frequencyLimit Int?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId, enabled])
  @@map("notification_preferences")
}

model NotificationTemplate {
  id              String                  @id @default(uuid())
  name            String
  type            NotificationTypeEnum
  language        String                  @default("en")
  channel         NotificationChannelEnum
  titleTemplate   String
  messageTemplate String
  metadataSchema  Json?
  isActive        Boolean                 @default(true)
  version         Int                     @default(1)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  notifications   Notification[]

  @@unique([name, version])
